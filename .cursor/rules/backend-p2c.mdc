## 3. 规约到代码的映射规则

### 3.1 scenarios → Service 方法分解

```typescript
// 由规约的 scenarios 和 errorCases 直接映射：
async addToCart(dto: AddToCartDto, memberId: string): Promise<CartItemVo> {
  // R-IN-CART-01, R-IN-CART-02: 输入校验（DTO 装饰器处理）
  this.validateAddInput(dto);

  // R-PRE-CART-01 ~ 06: 前置条件
  const product = await this.checkProductAvailable(dto.productId, dto.skuId);
  await this.checkTenantMatch(product);
  const currentQty = await this.checkCurrentCartQuantity(memberId, dto.skuId);

  // R-FLOW-CART-01, R-FLOW-CART-02: 主干逻辑
  const cartItem = await this.doAddToCart(memberId, dto, product, currentQty);

  // R-BRANCH-CART-01: 分支（超库存调整）
  await this.applyStockLimitRules(cartItem, product);

  return this.toCartItemVo(cartItem);
}
```

### 3.2 errorCases → BusinessException

```typescript
// 每个 errorCase 映射为一个 BusinessException.throwIf：

// R-PRE-CART-04
private async checkProductAvailable(productId: string, skuId: string) {
  const product = await this.productRepository.findByIdAndSku(productId, skuId);
  BusinessException.throwIfNull(product, '商品不存在或已下架');
  return product;
}

// R-PRE-CART-05
private checkStockAvailable(product: Product, requestQty: number) {
  BusinessException.throwIf(product.stock <= 0, '库存不足');
}

// R-PRE-CART-06
private async checkTenantMatch(product: Product) {
  const currentTenantId = this.cls.get('tenantId');
  BusinessException.throwIf(
    product.tenantId !== currentTenantId,
    '该商品不可用',
  );
}
```

### 3.3 stateTransitions → 状态机方法

```typescript
// 由 stateTransitions 映射：
private transitionOrderState(order: Order, targetState: OrderStatus) {
  const validTransitions: Record<OrderStatus, OrderStatus[]> = {
    [OrderStatus.PENDING]: [OrderStatus.PAID, OrderStatus.CANCELLED],
    [OrderStatus.PAID]: [OrderStatus.SHIPPED, OrderStatus.REFUNDING],
    // ...
  };

  const allowed = validTransitions[order.status] ?? [];
  BusinessException.throwIf(
    !allowed.includes(targetState),
    `订单状态 ${order.status} 无法转换为 ${targetState}`,
  );

  order.status = targetState;
}
```

