// 📌 分销规则配置表 (租户级)
// ==========================================

model SysDistConfig {
  id         Int     @id @default(autoincrement())
  tenantId   String  @unique @map("tenant_id") @db.VarChar(20) // 每个租户一套规则
  level1Rate Decimal @default(0.60) @map("level1_rate") @db.Decimal(5, 2) // 一级分佣比 (直推)
  level2Rate Decimal @default(0.40) @map("level2_rate") @db.Decimal(5, 2) // 二级分佣比 (间推)
  enableLV0  Boolean @default(true) @map("enable_lv0") // 是否允许普通用户参与分销

  // === 跨店分销配置 ===
  enableCrossTenant Boolean @default(false) @map("enable_cross_tenant") // 是否允许外店推荐人获取佣金
  crossTenantRate   Decimal @default(1.00) @map("cross_tenant_rate") @db.Decimal(5, 2) // 跨店分佣折扣 (1.00=100%, 0.80=80%)
  crossMaxDaily     Decimal @default(500.00) @map("cross_max_daily") @db.Decimal(10, 2) // 跨店佣金日限额

  // === 佣金计算策略 ===
  commissionBaseType CommissionBaseType @default(ORIGINAL_PRICE) @map("commission_base_type") // 佣金计算基数类型
  maxCommissionRate  Decimal            @default(0.50) @map("max_commission_rate") @db.Decimal(5, 2) // 最大佣金比例（熔断保护，如50%）

  createBy      String         @default("") @map("create_by") @db.VarChar(64)
  createTime    DateTime       @default(now()) @map("create_time")
  updateBy      String         @default("") @map("update_by") @db.VarChar(64)
  updateTime    DateTime       @updatedAt @map("update_time")
  playInstances PlayInstance[]

  @@map("sys_dist_config")
}

