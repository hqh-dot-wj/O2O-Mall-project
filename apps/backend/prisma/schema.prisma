// 📌 OMS 订单管理模块
// ==========================================

enum OrderStatus {
  PENDING_PAY @map("1") // 待支付
  PAID        @map("2") // 已支付待发货/待服务
  SHIPPED     @map("3") // 已发货/服务中
  COMPLETED   @map("4") // 已完成
  CANCELLED   @map("5") // 已取消
  REFUNDED    @map("6") // 已退款
}

enum OrderType {
  PRODUCT @map("1") // 实物订单
  SERVICE @map("2") // 服务订单
  MIXED   @map("3") // 混合订单
}

enum PayStatus {
  UNPAID   @map("0") // 未支付
  PAID     @map("1") // 已支付
  REFUNDED @map("2") // 已退款
}

/// 购物车表
model OmsCartItem {
  id       String @id @default(uuid())
  memberId String @map("member_id")
  tenantId String @map("tenant_id")

  productId String @map("product_id")
  skuId     String @map("sku_id")
  quantity  Int    @default(1)

  // 快照信息 (防止商品下架后报错)
  productName String  @map("product_name")
  productImg  String  @map("product_img")
  price       Decimal @db.Decimal(10, 2) // 加购时价格
  specData    Json?   @map("spec_data") // {"颜色":"红色"}

  // 归因信息
  shareUserId String? @map("share_user_id")

  // 服务类扩展
  serviceDate DateTime? @map("service_date")

  createTime DateTime @default(now()) @map("create_time")
  updateTime DateTime @updatedAt @map("update_time")

  @@unique([memberId, tenantId, skuId])
  @@index([memberId, tenantId])
  @@map("oms_cart_item")
}

/// 订单主表
model OmsOrder {
  id      String @id @default(cuid())
  orderSn String @unique @map("order_sn")

  memberId String @map("member_id")
  tenantId String @map("tenant_id")

  orderType OrderType @map("order_type")

  // 金额
  totalAmount    Decimal @map("total_amount") @db.Decimal(10, 2)
  freightAmount  Decimal @default(0) @map("freight_amount") @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(10, 2)
  payAmount      Decimal @map("pay_amount") @db.Decimal(10, 2)

  // 优惠券相关
  userCouponId   String? @map("user_coupon_id") // 使用的优惠券ID
  couponDiscount Decimal @default(0) @map("coupon_discount") @db.Decimal(10, 2) // 优惠券优惠金额

  // 积分相关
  pointsUsed     Int     @default(0) @map("points_used") // 使用的积分数量
  pointsDiscount Decimal @default(0) @map("points_discount") @db.Decimal(10, 2) // 积分抵扣金额
  pointsEarned   Int     @default(0) @map("points_earned") // 本次订单获得的积分

  // 收货信息
  receiverName    String? @map("receiver_name")
  receiverPhone   String? @map("receiver_phone")
  receiverAddress String? @map("receiver_address")
  receiverLat     Float?  @map("receiver_lat")
  receiverLng     Float?  @map("receiver_lng")

  // 服务类专属
  bookingTime   DateTime? @map("booking_time")
  workerId      Int?      @map("worker_id")
  serviceRemark String?   @map("service_remark")

  // 分销归因
  shareUserId String? @map("share_user_id")
  referrerId  String? @map("referrer_id")

  // 状态
  status    OrderStatus @default(PENDING_PAY)
  payStatus PayStatus   @default(UNPAID) @map("pay_status")

  // 支付信息
  payType       String?   @map("pay_type")
  transactionId String?   @map("transaction_id")
  payTime       DateTime? @map("pay_time")

  // 时间戳
  createTime DateTime  @default(now()) @map("create_time")
  updateTime DateTime  @updatedAt @map("update_time")
  deleteTime DateTime? @map("delete_time")

  remark String? @db.VarChar(500)

  items       OmsOrderItem[]
  commissions FinCommission[]
  tenant      SysTenant       @relation(fields: [tenantId], references: [tenantId])

  @@index([memberId, status])
  @@index([tenantId, createTime])
  @@map("oms_order")
}

/// 订单明细表
model OmsOrderItem {
  id       Int     @id @default(autoincrement())
  orderId  String  @map("order_id")
  tenantId String? @map("tenant_id") @db.VarChar(20)

  productId   String @map("product_id")
  productName String @map("product_name")
  productImg  String @map("product_img")

  skuId    String @map("sku_id")
  specData Json?  @map("spec_data")

  price       Decimal @db.Decimal(10, 2)
  quantity    Int
  totalAmount Decimal @map("total_amount") @db.Decimal(10, 2)

  // --- [新增] 积分相关 ---
  // 下单时的积分比例（快照，防止后续修改影响已下单商品）
  pointsRatio Int @default(100) @map("points_ratio")

  // 该商品产生的积分
  earnedPoints Int @default(0) @map("earned_points")

  order OmsOrder @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("oms_order_item")
}

// ==========================================
// 📌 财务中心表
// ==========================================

/// 用户钱包表
model FinWallet {
  id       String @id @default(uuid())
  memberId String @unique @map("member_id")
  tenantId String @map("tenant_id")

  // 三资产
  balance     Decimal @default(0) @db.Decimal(12, 2) // 可用余额
  frozen      Decimal @default(0) @db.Decimal(12, 2) // 冻结余额
  totalIncome Decimal @default(0) @db.Decimal(12, 2) // 累计收益

  // 安全
  payPassword String? @map("pay_password")
  version     Int     @default(0) // 乐观锁

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  member       UmsMember        @relation(fields: [memberId], references: [memberId])
  transactions FinTransaction[]

  @@index([tenantId, memberId])
  @@map("fin_wallet")
}

/// 钱包流水表 (不可篡改的账本)
model FinTransaction {
  id       BigInt @id @default(autoincrement())
  walletId String @map("wallet_id")
  tenantId String @map("tenant_id")

  type         TransType
  amount       Decimal   @db.Decimal(12, 2) // 可正可负
  balanceAfter Decimal   @db.Decimal(12, 2) // 交易后余额快照

  relatedId String  @map("related_id") // 关联业务ID
  remark    String? @db.VarChar(200)

  createTime DateTime @default(now()) @map("create_time")

  wallet FinWallet @relation(fields: [walletId], references: [id])

  @@index([walletId, createTime])
  @@index([tenantId, type])
  @@map("fin_transaction")
}

/// 佣金记录表 (在途资金)
/// 说明: 佣金分配比例从 SysDistConfig 表按 tenantId 获取
/// 计算流程: order.tenantId → SysDistConfig.tenantId → level1Rate/level2Rate
model FinCommission {
  id       BigInt @id @default(autoincrement())
  orderId  String @map("order_id")
  tenantId String @map("tenant_id")

  // [新增] 关联订单明细ID，支持部分退款按商品回收佣金
  orderItemId Int? @map("order_item_id")

  beneficiaryId String  @map("beneficiary_id") // 受益人
  level         Int // 1=一级(直推), 2=二级(间推)
  amount        Decimal @db.Decimal(10, 2)

  // 分佣比例快照 (记录当时的比例，防止配置修改后对账不准)
  rateSnapshot Decimal @default(0) @map("rate_snapshot") @db.Decimal(5, 2)

  // === 佣金计算详情（用于审计和对账） ===
  commissionBase     Decimal             @map("commission_base") @db.Decimal(10, 2) // 分佣基数
  commissionBaseType CommissionBaseType? @map("commission_base_type") // 基数类型快照
  orderOriginalPrice Decimal?            @map("order_original_price") @db.Decimal(10, 2) // 订单原价
  orderActualPaid    Decimal?            @map("order_actual_paid") @db.Decimal(10, 2) // 订单实付
  couponDiscount     Decimal?            @default(0) @map("coupon_discount") @db.Decimal(10, 2) // 优惠券抵扣
  pointsDiscount     Decimal?            @default(0) @map("points_discount") @db.Decimal(10, 2) // 积分抵扣
  isCapped           Boolean             @default(false) @map("is_capped") // 是否触发熔断

  status CommissionStatus @default(FROZEN)

  createTime     DateTime  @default(now()) @map("create_time")
  planSettleTime DateTime  @map("plan_settle_time") // 计划解冻时间
  settleTime     DateTime? @map("settle_time") // 实际解冻时间

  isCrossTenant Boolean @default(false) @map("is_cross_tenant") // 是否跨店佣金

  beneficiary UmsMember @relation(fields: [beneficiaryId], references: [memberId])

  order OmsOrder @relation(fields: [orderId], references: [id])

  @@unique([orderId, beneficiaryId, level]) // 防重复
  @@index([orderId])
  @@index([beneficiaryId, status])
  @@index([tenantId, status, planSettleTime]) // 定时任务索引
  @@index([orderItemId]) // 支持按商品查询
  @@map("fin_commission")
}

/// 用户每日配额表 (用于跨店限额并发控制)
/// 说明: 使用专门的计数器表，避免 SELECT SUM FOR UPDATE 的首笔并发漏洞
model FinUserDailyQuota {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  beneficiaryId String   @map("beneficiary_id")
  quotaDate     DateTime @map("quota_date") @db.Date
  usedAmount    Decimal  @default(0) @map("used_amount") @db.Decimal(10, 2)
  limitAmount   Decimal  @map("limit_amount") @db.Decimal(10, 2)
  createTime    DateTime @default(now()) @map("create_time")
  updateTime    DateTime @updatedAt @map("update_time")

  @@unique([tenantId, beneficiaryId, quotaDate])
  @@index([tenantId, beneficiaryId, quotaDate])
  @@map("fin_user_daily_quota")
}

/// 提现记录表
model FinWithdrawal {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  memberId String @map("member_id")

  amount Decimal @db.Decimal(10, 2)
  method String // WECHAT_WALLET, BANK_CARD

  // 账号快照
  accountNo String?
  realName  String?

  status WithdrawalStatus @default(PENDING)

  auditTime   DateTime? @map("audit_time")
  auditBy     String?   @map("audit_by")
  auditRemark String?   @map("audit_remark")

  // 打款凭证
  paymentNo  String? @map("payment_no") // 微信流水号
  failReason String? @map("fail_reason")

  createTime DateTime @default(now()) @map("create_time")

  member UmsMember @relation(fields: [memberId], references: [memberId])

  @@index([tenantId, status])
  @@index([memberId, createTime])
  @@map("fin_withdrawal")
}

