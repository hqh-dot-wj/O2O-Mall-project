generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

// Prisma 默认使用 DATABASE_URL，但我们会在 Nest 的 PrismaService 中按需注入连接串。
datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

enum Status {
  NORMAL @map("0")
  STOP   @map("1")
}

enum DelFlag {
  NORMAL @map("0")
  DELETE @map("1")
}

// ==================== C端/SaaS 业务表 (Refactored) ====================

enum MemberStatus {
  NORMAL   @map("1") // 正常
  DISABLED @map("2") // 禁用
}

enum SocialPlatform {
  MP_MALL
  MP_WORK
  APP_MAIN
}

enum WorkerStatus {
  WORKING  @map("1") // 接单中 (营业)
  RESTING  @map("2") // 休息中 (打烊)
  FROZEN   @map("3") // 冻结中 (暂停)
  RESIGNED @map("4") // 离职中 (离职)
}

enum AuditStatus {
  PENDING  @map("0") // 待审核
  APPROVED @map("1") // 通过
  REJECTED @map("2") // 驳回
}

enum WorkerLevel {
  PRIMARY @map("1") // 初级
  MIDDLE  @map("2") // 中级
  SENIOR  @map("3") // 高级
  GOLD    @map("4") // 金牌
}

enum Gender {
  UNKNOWN @map("0") // 未知
  MALE    @map("1") // 男
  FEMALE  @map("2") // 女
}

enum MediaType {
  IMAGE @map("1") // 图片
  VIDEO @map("2") // 视频
}

enum SkillLevel {
  GENERAL @map("1") // 一般
  MASTER  @map("2") // 精通
}

enum WageType {
  HOURLY     @map("1") // 时薪制 (如: 保洁 80/小时)
  PERCENTAGE @map("2") // 分成制 (如: 维修 平台抽20%)
  FIXED      @map("3") // 一口价 (如: 搬家 200/次)
}

enum AttrUsageType {
  PARAM // 参数 (详情页展示)
  SPEC // 规格 (SKU生成用)
}

enum SettleType {
  WALLET // 进App钱包
  BANK // 银行卡/线下打款
}

enum ProductType {
  REAL // 实物商品 (需发货，扣绝对库存)
  SERVICE // 服务商品 (需核销，扣时间片/每日运力)
}

enum PublishStatus {
  OFF_SHELF // 下架
  ON_SHELF // 上架
}

// ==========================================
// 📌 财务系统枚举
// ==========================================

/// 交易类型
enum TransType {
  COMMISSION_IN // 佣金入账
  WITHDRAW_OUT // 提现扣款
  REFUND_DEDUCT // 退款倒扣
  CONSUME_PAY // 余额支付
  RECHARGE_IN // 充值(预留)
}

/// 佣金状态
enum CommissionStatus {
  FROZEN // 冻结中
  SETTLED // 已结算
  CANCELLED // 已取消
}

/// 提现状态
enum WithdrawalStatus {
  PENDING // 待审核
  APPROVED // 已通过
  REJECTED // 已驳回
  FAILED // 打款失败
}

// ==========================================
// 📌 商品类别与属性
// ==========================================

/// 商品分类表 (树形结构)
model PmsCategory {
  catId    Int     @id @default(autoincrement()) @map("cat_id")
  parentId Int?    @map("parent_id")
  name     String  @db.VarChar(50)
  level    Int // 1, 2, 3
  icon     String?
  sort     Int     @default(0)

  // --- 关键：类型绑定 ---
  // 比如"保洁"分类只能发服务，"清洁剂"分类只能发实物
  bindType ProductType? @map("bind_type")

  // [新增] 关联属性模板 ID
  attrTemplateId Int? @map("attr_template_id")

  attrTemplate PmsAttrTemplate? @relation(fields: [attrTemplateId], references: [templateId])

  parent   PmsCategory?  @relation("CatTree", fields: [parentId], references: [catId])
  children PmsCategory[] @relation("CatTree")
  products PmsProduct[]

  @@map("pms_category")
}

/// 品牌表 (主要用于实物)
model PmsBrand {
  brandId Int     @id @default(autoincrement()) @map("brand_id")
  name    String
  logo    String?

  products PmsProduct[]

  @@map("pms_brand")
}

// ==========================================
// 📌 [新增] 商品参数/属性模板系统
// ==========================================

/// 1. 属性分类/模板表 (Attribute Group)
/// 作用：将一堆属性打包。例如: "手机参数模板", "家政保洁模板"
model PmsAttrTemplate {
  templateId Int    @id @default(autoincrement()) @map("template_id")
  name       String @db.VarChar(64)

  // 关联分类 (通常是一对多，一个模板可以给多个分类用)
  categories PmsCategory[]
  attributes PmsAttribute[]

  createTime DateTime @default(now()) @map("create_time")

  @@map("pms_attr_template")
}

/// 2. 属性名定义表 (Attribute Key)
/// 作用：定义具体的字段。如: "材质", "服务时长"
model PmsAttribute {
  attrId     Int @id @default(autoincrement()) @map("attr_id")
  templateId Int @map("template_id")

  name String @db.VarChar(64) // 属性名: "材质" / "服务范围"

  // --- 核心类型区分 ---
  // PARAM: 基本参数 (纯展示，如: 产地)
  // SPEC:  销售属性 (决定SKU，如: 颜色)
  usageType AttrUsageType @map("usage_type")

  // --- 适用商品类型 (实物/服务) ---
  // 0:通用 1:实物专用 2:服务专用
  // 比如 "保修期" 是实物专用，"上门时间" 是服务专用
  applyType Int @default(0) @map("apply_type")

  // --- 录入方式 ---
  // 0: 手工录入 (Input)
  // 1: 列表选择 (Select)
  inputType Int @default(0) @map("input_type")

  // --- 可选值列表 (逗号分隔) ---
  // 如: "棉,麻,丝绸" 或 "挂机,柜机"
  inputList String? @map("input_list")

  sort Int @default(0)

  template PmsAttrTemplate       @relation(fields: [templateId], references: [templateId])
  values   PmsProductAttrValue[]

  @@map("pms_attribute")
}

/// 3. 商品属性值存储表 (Attribute Value)
/// 作用：记录某个商品选了什么值。如: 商品A - 材质 - 棉
model PmsProductAttrValue {
  id        Int    @id @default(autoincrement())
  productId String @map("product_id")
  attrId    Int    @map("attr_id")

  // 冗余属性名，防止模板删了商品显示不出来
  attrName String @map("attr_name")

  // 实际选的值 (如: "棉")
  value String @map("value")

  product   PmsProduct   @relation(fields: [productId], references: [productId])
  attribute PmsAttribute @relation(fields: [attrId], references: [attrId])

  @@index([productId])
  @@map("pms_product_attr_value")
}

// ==========================================
// 📌 商品标准库 (总部视角 - Global SPU)
// ==========================================

model PmsProduct {
  productId  String @id @default(uuid()) @map("product_id")
  categoryId Int    @map("cat_id")
  brandId    Int?   @map("brand_id")

  // --- 基础信息 ---
  name       String   @db.VarChar(100)
  subTitle   String?  @map("sub_title") // 卖点描述
  mainImages String[] @map("main_images") // 轮播图
  detailHtml String   @map("detail_html") @db.Text // 富文本详情

  // --- 核心类型区分 ---
  type ProductType

  // --- [差异化字段] 实物特有 ---
  weight     Int? // 重量(克)，用于算运费
  isFreeShip Boolean @default(false) @map("is_free_ship") // 是否包邮

  // --- [差异化字段] 服务特有 ---
  serviceDuration Int?    @map("service_duration") // 服务时长(分钟)，用于排班占位
  serviceRadius   Int?    @map("service_radius") // 默认服务半径(米)，门店可重写
  needBooking     Boolean @default(true) @map("need_booking") // 是否需要预约

  // --- 规格定义 ---
  // 存储: [{"name": "颜色", "values": ["红", "蓝"]}]
  specDef Json @map("spec_def")

  // --- [新增] 上架状态 (Selection Center可见性) ---
  publishStatus PublishStatus @default(ON_SHELF) @map("publish_status")

  // --- [新增] 软删除标记 ---
  delFlag DelFlag @default(NORMAL) @map("del_flag")

  createTime DateTime @default(now()) @map("create_time")

  // 关联
  category       PmsCategory           @relation(fields: [categoryId], references: [catId])
  brand          PmsBrand?             @relation(fields: [brandId], references: [brandId])
  // [新增] 关联属性值
  attrValues     PmsProductAttrValue[]
  globalSkus     PmsGlobalSku[]
  tenantProducts PmsTenantProduct[]

  @@index([categoryId])
  @@map("pms_product")
}

/// 标准 SKU 表 (总部定价参考)
model PmsGlobalSku {
  skuId     String @id @default(uuid()) @map("sku_id")
  productId String @map("product_id")

  // --- 规格组合 ---
  // 实物: {"颜色":"红", "尺寸":"L"}
  // 服务: {"时长":"2小时", "级别":"金牌技师"}
  specValues Json @map("spec_values")

  // --- 索引图 ---
  skuImage String? @map("sku_image")

  // --- 总部指导价 ---
  guidePrice Decimal @map("guide_price") @db.Decimal(10, 2)

  // --- [新增] 总部指导分佣配置 ---
  distMode DistributionMode @default(RATIO) @map("dist_mode")

  // 指导比例 (0.10 代表 10%) 或 指导金额 (10.00元)
  guideRate Decimal @default(0.00) @map("guide_rate") @db.Decimal(10, 2)

  // [新增] 必须加这两个字段，否则无法实现"不能比总部低/高"的管控
  minDistRate Decimal @default(0.00) @map("min_dist_rate") @db.Decimal(10, 2) // 最低允许比例 (如 5%)
  maxDistRate Decimal @default(50.00) @map("max_dist_rate") @db.Decimal(10, 2) // 最高允许比例 (如 30%)

  // 成本价 (用于风控校验 (price - cost) > commission)
  costPrice Decimal @default(0.00) @map("cost_price") @db.Decimal(10, 2)

  product       PmsProduct     @relation(fields: [productId], references: [productId])
  pmsTenantSkus PmsTenantSku[]

  @@map("pms_global_sku")
}

// ==========================================
// 📌 门店经营库 (分公司视角 - Tenant SPU)
// ==========================================

model PmsTenantProduct {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id") // 归属门店
  productId String @map("product_id") // 引用总部商品

  // --- 经营状态 ---
  status PublishStatus @default(OFF_SHELF)
  isHot  Boolean       @default(false) // 是否设为店长推荐
  sort   Int           @default(0)

  // --- 门店重写数据 (Override) ---
  // 如果填了，就覆盖总部的标题/图片；没填就继承
  customTitle String? @map("custom_title")

  // --- [服务特有] 门店派单规则 ---
  // 比如这家店只接方圆3公里的单，另一家能接10公里
  overrideRadius Int? @map("override_radius")

  createTime DateTime @default(now()) @map("create_time")

  product PmsProduct     @relation(fields: [productId], references: [productId])
  skus    PmsTenantSku[] // 门店的SKU价格库存

  @@unique([tenantId, productId]) // 一个店不能重复上架同一个商品
  @@map("pms_tenant_product")
}

/// 门店 SKU 表 (真正的价格和库存都在这里)
model PmsTenantSku {
  id              String       @id @default(uuid())
  tenantId        String       @map("tenant_id") @db.VarChar(20)
  tenantProductId String       @map("tenant_prod_id")
  globalSkuId     String       @map("global_sku_id") // 对应哪个标准SKU
  globalSku       PmsGlobalSku @relation(fields: [globalSkuId], references: [skuId])

  // --- 核心经营数据 ---
  price Decimal @db.Decimal(10, 2) // 门店实际售价

  // --- 库存/运力定义的歧义处理 ---
  // 1. 实物: 真实的物理库存。卖一个少一个。
  // 2. 服务: 每日最大接单量 (Capacity)。如果不限制填 -1。
  //    (注意: 服务的真正"库存"是根据技师排班表实时计算的，这个字段仅做硬性上限)
  stock Int @default(0)

  isActive Boolean @default(true) // 比如这家店"红色"卖完了，可以单独下架这个SKU

  // --- [新增] 门店实际分佣配置 ---
  // 门店有权修改这个比例 (通常不能低于总部设定的底线，后端可做校验)
  distMode DistributionMode @default(RATIO) @map("dist_mode")

  // 实际执行比例 (例如总部建议 10%，门店想多推销，设为 15%)
  distRate Decimal @default(0.00) @map("dist_rate") @db.Decimal(10, 2)

  // --- [新增] 兑换商品标识 ---
  // 标识该商品是否为兑换商品（优惠券/积分全额兑换，不参与分佣）
  isExchangeProduct Boolean @default(false) @map("is_exchange_product")

  // --- [新增] 乐观锁版本号 ---
  // 用于防止并发更新冲突,每次更新时自动+1
  version Int @default(0)

  // --- [新增] 积分配置 ---
  // 积分获得比例（0-100，默认100表示正常获得积分，0表示不产生积分）
  pointsRatio Int @default(100) @map("points_ratio")

  // 是否营销活动商品
  isPromotionProduct Boolean @default(false) @map("is_promotion_product")

  tenantProd PmsTenantProduct @relation(fields: [tenantProductId], references: [id])

  @@map("pms_tenant_sku")
}

enum DistributionMode {
  RATIO // 按比例 (如: 销售额的 10%)
  FIXED // 按固定金额 (如: 每单固定分 10 元)
  NONE // 不参与分销 (如: 特价引流品)
}

/// 佣金计算基数类型
enum CommissionBaseType {
  ORIGINAL_PRICE // 基于商品原价（优惠由平台承担）
  ACTUAL_PAID // 基于实付金额（优惠由推广者承担）
  ZERO // 不分佣（兑换商品）
}

/// C端会员表 (一切业务的源头)
model UmsMember {
  memberId String @id @default(uuid()) @map("member_id")
  tenantId String @default("000000") @map("tenant_id") // 归属租户

  // --- 基础信息 ---
  nickname String? @db.VarChar(64)
  avatar   String? @db.VarChar(500)
  mobile   String? @unique @db.VarChar(20)
  password String? @db.VarChar(200)

  // --- 状态与等级 ---
  status  MemberStatus @default(NORMAL)
  levelId Int          @default(0) @map("level_id") // 0=C普通, 1=C1团长, 2=C2股东

  // --- 钱包资产 (分销核心) ---
  balance       Decimal @default(0.00) @db.Decimal(10, 2) // 可提现余额
  frozenBalance Decimal @default(0.00) @db.Decimal(10, 2) // 冻结余额
  points        Int     @default(0) // 积分

  // --- 三级分销关系链 ---
  parentId         String? @map("parent_id") // 直接上级 (C1或C2)
  indirectParentId String? @map("indirect_parent_id") // 间接上级 (C2)
  referralCode     String? @unique @map("referral_code") // 推荐码 (仅C2, 格式: T001-XXXX)

  // --- 升级信息 ---
  upgradedAt     DateTime? @map("upgraded_at") // 升级时间
  upgradeOrderId String?   @map("upgrade_order_id") // 通过购买升级时的订单ID

  // --- 时间 ---
  createTime DateTime @default(now()) @map("create_time")
  updateTime DateTime @updatedAt @map("update_time")

  // --- 分销关联 ---
  parent         UmsMember?  @relation("ParentChild", fields: [parentId], references: [memberId])
  directChildren UmsMember[] @relation("ParentChild") // 我的直接下级

  indirectParent   UmsMember?  @relation("IndirectParentChild", fields: [indirectParentId], references: [memberId])
  indirectChildren UmsMember[] @relation("IndirectParentChild") // 我的间接下级

  socials         SysSocialUser[]
  workers         SrvWorker[] // 1:N 技师关联 (多租户兼职)
  sysRegionAgents SysRegionAgent[]
  umsAddresses    UmsAddress[]

  // --- 财务关联 ---
  wallet      FinWallet?
  commissions FinCommission[]
  withdrawals FinWithdrawal[]

  @@index([mobile])
  @@index([parentId])
  @@index([indirectParentId])
  @@index([tenantId, levelId])
  @@map("ums_member")
}

/// 会员升级申请表
model UmsUpgradeApply {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id") @db.VarChar(20)
  memberId String @map("member_id")

  fromLevel Int @map("from_level") // 原等级 (0/1)
  toLevel   Int @map("to_level") // 目标等级 (1/2)

  applyType    String  @map("apply_type") // PRODUCT_PURCHASE / REFERRAL_CODE
  referralCode String? @map("referral_code") // 扫码申请时的推荐码
  orderId      String? @map("order_id") // 购买升级商品时的订单ID
  referrerId   String? @map("referrer_id") // 推荐人ID (从推荐码解析)

  status       String    @default("PENDING") // PENDING / APPROVED / REJECTED
  reviewBy     String?   @map("review_by")
  reviewTime   DateTime? @map("review_time")
  reviewRemark String?   @map("review_remark") @db.VarChar(500)

  createTime DateTime @default(now()) @map("create_time")

  @@index([tenantId, memberId])
  @@index([status])
  @@map("ums_upgrade_apply")
}

/// C2推荐码表 (带租户前缀: T001-XXXX)
model UmsReferralCode {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id") @db.VarChar(20)
  memberId String @map("member_id") // 归属人 (仅C2可有)

  code      String  @unique // 格式: T001-XXXX
  qrCodeUrl String? @map("qr_code_url") @db.VarChar(500) // 小程序码URL

  usageCount Int     @default(0) @map("usage_count") // 使用次数
  isActive   Boolean @default(true) @map("is_active")

  createTime DateTime @default(now()) @map("create_time")

  @@unique([tenantId, memberId])
  @@index([code])
  @@map("ums_referral_code")
}

/// 社交账号绑定表
model SysSocialUser {
  socialId String @id @default(uuid()) @map("social_id")
  memberId String @map("member_id")

  platform SocialPlatform // 平台标识

  openid  String  @db.VarChar(64)
  unionid String? @db.VarChar(64) // 跨端识别关键

  nickname   String?
  avatar     String?
  sessionKey String? @map("session_key")

  member UmsMember @relation(fields: [memberId], references: [memberId])

  @@unique([platform, openid])
  @@index([memberId])
  @@index([unionid])
  @@map("sys_social_user")
}

/// 用户收货地址表
model UmsAddress {
  id       String @id @default(uuid())
  memberId String @map("member_id")

  // 收货人信息
  name  String @db.VarChar(50) // 收货人姓名
  phone String @db.VarChar(20) // 联系电话

  // 地址信息 (省市区 + 详细地址)
  province String @db.VarChar(50) // 省
  city     String @db.VarChar(50) // 市
  district String @db.VarChar(50) // 区/县
  detail   String @db.VarChar(500) // 详细地址

  // LBS 定位信息 (可选，用于服务范围校验)
  latitude  Float? // 纬度
  longitude Float? // 经度

  // 标识
  isDefault Boolean @default(false) @map("is_default") // 是否默认地址
  tag       String? @db.VarChar(20) // 标签: 家、公司、学校

  createTime DateTime @default(now()) @map("create_time")
  updateTime DateTime @updatedAt @map("update_time")

  member UmsMember @relation(fields: [memberId], references: [memberId])

  @@index([memberId])
  @@map("ums_address")
}

// ==========================================
// 📌 劳动者/技师核心 (Service Worker)
// ==========================================

/// 劳动者主表 (高频访问核心表)
model SrvWorker {
  workerId Int    @id @default(autoincrement()) @map("worker_id")
  memberId String @map("member_id") // 关联C端账号
  tenantId String @map("tenant_id") // 归属分公司

  // --- 核心展示 ---
  name     String  @db.VarChar(50)
  nickName String? @map("nick_name")
  avatar   String? @db.VarChar(500)
  phone    String  @db.VarChar(20)

  // --- 业务状态 ---
  status      WorkerStatus @default(WORKING)
  auditStatus AuditStatus  @default(PENDING) @map("audit_status")
  isOnline    Boolean      @default(true) @map("is_online") // 接单开关

  // --- LBS 派单核心 (新增) ---
  currentLat    Float? @map("current_lat") // 实时纬度 (Redis也会存，这里存最后一次)
  currentLng    Float? @map("current_lng") // 实时经度
  serviceRadius Int    @default(5000) @map("service_radius") // 服务半径(米)

  // --- 薪资配置 (新增 - 用于算工资) ---
  wageType WageType @default(HOURLY) @map("wage_type")
  baseWage Decimal  @default(0.00) @map("base_wage") @db.Decimal(10, 2) // 时薪或分成比例

  // --- 权重数据 ---
  rating     Decimal     @default(5.0) @db.Decimal(2, 1)
  orderCount Int         @default(0) @map("order_count")
  seniority  WorkerLevel @default(PRIMARY)
  tags       Json? // ["擅长收纳", "自带工具"]

  createTime DateTime @default(now()) @map("create_time")
  updateTime DateTime @updatedAt @map("update_time")

  // --- 关联 ---
  member UmsMember @relation(fields: [memberId], references: [memberId])

  profile   SrvWorkerProfile?
  certs     SrvWorkerCert[]
  skills    SrvWorkerSkill[]
  works     SrvWorkerWork[]
  schedules SrvWorkerSchedule[] // 排班记录

  @@unique([memberId, tenantId])
  @@index([tenantId, status]) // 租户筛选+状态筛选
  @@index([phone])
  @@map("srv_worker")
}

/// 劳动者详细档案 (隐私/低频信息)
