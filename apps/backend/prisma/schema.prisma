  @@index([requestTenantId, createTime])
  @@index([accessTenantId, createTime])
  @@index([userId, createTime])
  @@index([isCrossTenant, createTime])
  @@index([status, createTime])
  @@index([traceId])
  @@map("sys_tenant_audit_log")
}

/// [新增] 区域代理商表 (O2O 分销)
model SysRegionAgent {
  agentId  Int    @id @default(autoincrement()) @map("agent_id")
  tenantId String @map("tenant_id") @db.VarChar(20)

  // --- 1. 身份定义 ---
  regionCode String @map("region_code") // 独家盘口 "430103"
  agentName  String @map("agent_name") // 代理商名称 (如: "长沙聚力有限公司" 或 "王总")
  phone      String @map("phone") // 联系电话 (用于通知)

  // --- 2. 关联 C 端账号 (变为可选) ---
  // 如果这个代理商想在 App 上看报表，就绑定一个账号；
  // 如果他只等着每月收钱，完全不用 App，这里就是 null。
  memberId String? @map("member_id")

  // --- 3. 利益分配 ---
  level Int     @default(3) // 1:省 2:市 3:区
  rate  Decimal @db.Decimal(5, 4) // 分红比例 0.05

  // --- 4. 独立的 B 端结算档案 (核心) ---
  settleType  SettleType @default(BANK) // BANK:银行转账, WALLET:钱包
  bankName    String?    @map("bank_name") // 开户行 (招商银行长沙分行)
  accountName String?    @map("account_name") // 户名 (张三 / xx公司)
  accountNo   String?    @map("account_no") // 卡号

  // --- 5. 独立的 B 端账本 ---
  // 代理商的钱不进 Member 钱包，在这里单独统计
  totalIncome   Decimal @default(0.00) @map("total_income") // 累计总收益
  pendingSettle Decimal @default(0.00) @map("pending_settle") // 待结算金额 (上个月赚的，还没打款)
  alreadySettle Decimal @default(0.00) @map("already_settle") // 已打款金额

  createTime DateTime @default(now())

  // 关联 (可选)
  member UmsMember? @relation(fields: [memberId], references: [memberId])

  @@unique([tenantId, regionCode])
  @@map("sys_region_agent")
}

